# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is git-ignored for this reason.
# NEVER paste real credentials into any chat or email.
# Every variable the project needs is listed here with a placeholder only.

# PostgreSQL connection string (from Supabase: Project Settings > Database > URI)
DATABASE_URL=postgres://postgres:your-database-password@db.your-project-ref.supabase.co:5432/postgres

# Supabase project URL and API keys (from Supabase: Project Settings > API)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Supabase Storage bucket name for raw data lake
STORAGE_BUCKET=raw-lake
